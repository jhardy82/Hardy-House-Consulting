{
  "name": "hardy-house",
  "version": "0.1.0",
  "type": "module",
  "description": "Hardy House Consulting App",
  "scripts": {
    "dev": "nodemon --exec \"node --env-file=.env\" server.js",
    "start": "node server.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:unit": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/unit/",
    "test:api": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/api/",
    "test:e2e": "playwright test",
    "lint": "eslint public/js/ routes/ tasks/"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "compression": "^1.8.1",
    "express": "^4.18",
    "express-rate-limit": "^8.4.1",
    "express-session": "^1.17",
    "helmet": "^8.1.0",
    "resend": "^6.12.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.44",
    "eslint": "^8",
    "jest": "^29",
    "nodemon": "^3",
    "supertest": "^6"
  }
}
